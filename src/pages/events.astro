---
import Base from '../layouts/Base.astro'
import { SITE, ASSETS } from '../lib/const'

const pageTitle = `Events — ${SITE.short}`
const pageDescription =
	'Upcoming special events and regular weekly services at Hope Community SDA Church, Beckenham.'

const upcomingEvents = [
	{
		date: '18 July',
		title: 'International Day',
		description: 'A celebration of our diverse community from around the world.',
	},
	{
		date: '6 September',
		title: 'Summer BBQ',
		description: 'Join us for fellowship, food, and fun at our annual summer gathering.',
	},
	{
		date: '12 December',
		title: 'Christmas Programme',
		description: 'A special service celebrating the birth of Jesus Christ.',
	},
]

const regularEvents = [
	{
		day: 'Saturday',
		items: [
			{ time: '10:00', label: 'Bible Study Hour' },
			{ time: '11:15', label: 'Main Service' },
		],
	},
	{
		day: 'Wednesday',
		items: [
			{ time: '19:30', label: 'Prayer Meeting' },
		],
	},
]
---

<Base
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={`${SITE.url}/events`}
>
	<div class="relative flex min-h-[100dvh] min-h-[100svh] flex-col overflow-x-clip">
		<!-- Subtle background grain -->
		<div class="bg-grain pointer-events-none fixed inset-0 opacity-40" aria-hidden="true"></div>

		<!-- Header -->
		<header class="relative z-10 pt-safe">
			<div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 pt-4 sm:gap-4 sm:px-8 sm:pt-8">
				<a
					href="/"
					class="animate-fade flex min-w-0 flex-1 items-center gap-2.5 sm:min-w-0 sm:flex-none sm:gap-3"
					aria-label={SITE.name}
				>
					<img
						src={ASSETS.logo}
						alt=""
						width="40"
						height="40"
						class="h-10 w-10 shrink-0 rounded-full bg-white/5 object-contain p-1 ring-1 ring-white/15 sm:h-11 sm:w-11"
						loading="eager"
					/>
					<span class="truncate text-left text-sm font-semibold leading-tight tracking-tight text-brand-cream sm:text-lg">
						Hope SDA Church
					</span>
				</a>
				<nav class="animate-fade flex shrink-0 items-center gap-2 sm:gap-3">
					<a
						href="/"
						class="hidden items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-medium text-brand-cream/90 backdrop-blur transition hover:bg-white/10 sm:inline-flex"
					>
						← Home
					</a>
					<a
						href={`mailto:${SITE.contactEmail}`}
						class="touch-target inline-flex rounded-full border border-white/15 bg-white/5 text-brand-cream/90 backdrop-blur transition active:bg-white/15 hover:bg-white/10 sm:hidden"
						aria-label="Email us"
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
							<polyline points="22,6 12,13 2,6" />
						</svg>
					</a>
				</nav>
			</div>
		</header>

		<!-- Page content -->
		<main class="relative z-10 mx-auto w-full max-w-4xl flex-1 px-4 pb-16 pt-12 sm:px-8 sm:pt-20">

			<!-- Page heading -->
			<div class="animate-fade-up mb-12 text-center sm:mb-16">
				<p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-brand-sky/80">
					Hope Community SDA
				</p>
				<h1 class="font-display text-4xl font-semibold text-brand-cream sm:text-5xl lg:text-6xl">
					Events
				</h1>
				<p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-brand-muted">
					Join us at {SITE.address.line1}, {SITE.address.line2}.
				</p>
			</div>

			<!-- Upcoming Events -->
			<section class="animate-fade-up mb-14" style="animation-delay: 0.1s">
				<h2 class="mb-6 text-xs font-semibold uppercase tracking-[0.2em] text-brand-gold">
					Upcoming Events
				</h2>
				<ul class="space-y-4">
					{upcomingEvents.map((event) => (
						<li>
							<div class="glass rounded-2xl p-5 sm:p-6 transition hover:border-white/15">
								<div class="flex items-start gap-4">
									<div class="flex min-w-[4.5rem] flex-col items-center rounded-xl border border-brand-gold/20 bg-brand-gold/10 px-3 py-2 text-center">
										<span class="font-display text-xl font-semibold leading-none text-brand-gold">
											{event.date.split(' ')[0]}
										</span>
										<span class="mt-0.5 text-[0.65rem] font-medium uppercase tracking-wider text-brand-gold/70">
											{event.date.split(' ')[1]}
										</span>
									</div>
									<div class="min-w-0 flex-1">
										<h3 class="text-base font-semibold text-brand-cream sm:text-lg">
											{event.title}
										</h3>
										<p class="mt-1 text-sm leading-relaxed text-brand-muted">
											{event.description}
										</p>
									</div>
								</div>
							</div>
						</li>
					))}
				</ul>
			</section>

			<!-- Regular Events -->
			<section class="animate-fade-up" style="animation-delay: 0.2s">
				<h2 class="mb-6 text-xs font-semibold uppercase tracking-[0.2em] text-brand-sky">
					Weekly Services
				</h2>
				<div class="grid gap-4 sm:grid-cols-2">
					{regularEvents.map((group) => (
						<div class="glass rounded-2xl p-5 sm:p-6">
							<h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-brand-cream/70">
								{group.day}s
							</h3>
							<ul class="space-y-3">
								{group.items.map((item) => (
									<li class="flex items-center gap-3">
										<span class="inline-flex shrink-0 items-center rounded-lg border border-brand-sky/20 bg-brand-sky/10 px-2.5 py-1 font-mono text-xs font-medium text-brand-sky">
											{item.time}
										</span>
										<span class="text-sm text-brand-cream/90">{item.label}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</section>

		</main>

		<!-- Footer -->
		<footer class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-5 px-4 pb-safe pt-2 text-center sm:flex-row sm:items-center sm:gap-4 sm:px-8 sm:pt-0 sm:text-left">
			<p class="max-w-md text-xs leading-relaxed text-brand-muted sm:max-w-none">
				© {new Date().getFullYear()} Hope Community SDA Church · A family church in Beckenham, Bromley.
			</p>
			<div class="flex items-center gap-4" aria-label="Follow us">
				<a
					href={SITE.social.facebook}
					target="_blank"
					rel="noreferrer"
					aria-label="Facebook"
					class="touch-target grid h-11 w-11 place-items-center rounded-full border border-white/15 bg-white/5 text-brand-cream/80 transition active:bg-white/10 hover:border-white/30 hover:text-brand-cream"
				>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.1.4-2 2-2h2V2.2C16.6 2.1 15.3 2 14 2c-3 0-5 1.8-5 5.1V10H6v4h3v8h4z" /></svg>
				</a>
				<a
					href={SITE.social.instagram}
					target="_blank"
					rel="noreferrer"
					aria-label="Instagram"
					class="touch-target grid h-11 w-11 place-items-center rounded-full border border-white/15 bg-white/5 text-brand-cream/80 transition active:bg-white/10 hover:border-white/30 hover:text-brand-cream"
				>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
						<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
					</svg>
				</a>
				<a
					href={SITE.social.youtube}
					target="_blank"
					rel="noreferrer"
					aria-label="YouTube — weekly live streams"
					class="touch-target grid h-11 w-11 place-items-center rounded-full border border-white/15 bg-white/5 text-brand-cream/80 transition active:bg-white/10 hover:border-red-500/40 hover:text-red-200"
				>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 7.3s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.9 3.8 12 3.8 12 3.8s-4.9 0-7.9.2c-.4.1-1.4.1-2.2 1C1.2 5.7 1 7.3 1 7.3S.8 9.2.8 11.1v1.8C.8 14.8 1 16.7 1 16.7s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.7.2 7.7.2s4.9 0 7.9-.2c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.8c0-1.9-.2-3.8-.2-3.8zM9.8 14.9V8.5l6.2 3.2-6.2 3.2z" /></svg>
				</a>
			</div>
		</footer>

	</div>
</Base>
