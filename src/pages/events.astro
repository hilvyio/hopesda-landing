---
import Base from '../layouts/Base.astro'
import { SITE, ASSETS } from '../lib/const'

const pageTitle = `Events — ${SITE.short}`
const pageDescription =
	'Upcoming special events and regular weekly services at Hope Community SDA Church, Beckenham.'

const upcomingEvents = [
	{
		date: '18 July',
		title: 'International Day',
		description: 'A celebration of our diverse community from around the world.',
	},
	{
		date: '6 September',
		title: 'Summer BBQ',
		description: 'Join us for fellowship, food, and fun at our annual summer gathering.',
	},
	{
		date: '12 December',
		title: 'Christmas Programme',
		description: 'A special service celebrating the birth of Jesus Christ.',
	},
]

const regularEvents = [
	{
		day: 'Saturday',
		items: [
			{ time: '10:00', label: 'Bible Study Hour' },
			{ time: '11:15', label: 'Main Service' },
		],
	},
	{
		day: 'Wednesday',
		items: [
			{ time: '19:30', label: 'Prayer Meeting' },
		],
	},
]
---

<Base
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={`${SITE.url}/events`}
>
	<div class="relative flex min-h-[100dvh] min-h-[100svh] flex-col overflow-x-clip bg-[#f5f0e8]">

		<!-- Header -->
		<header class="relative z-10 border-b border-black/8 bg-white/80 pt-safe backdrop-blur">
			<div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3 sm:gap-4 sm:px-8 sm:py-4">
				<a
					href="/"
					class="flex min-w-0 flex-1 items-center gap-2.5 sm:min-w-0 sm:flex-none sm:gap-3"
					aria-label={SITE.name}
				>
					<img
						src={ASSETS.logo}
						alt=""
						width="40"
						height="40"
						class="h-10 w-10 shrink-0 rounded-full bg-gray-800 object-contain p-1 ring-1 ring-gray-700 sm:h-11 sm:w-11"
						loading="eager"
					/>
					<span class="truncate text-left text-sm font-semibold leading-tight tracking-tight text-gray-900 sm:text-base">
						Hope SDA Church
					</span>
				</a>
				<nav class="flex shrink-0 items-center gap-2 sm:gap-3">
					<a
						href="/"
						class="inline-flex items-center gap-1.5 rounded-full bg-[#1a4a7a] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#15396a]"
					>
						← Home
					</a>
				</nav>
			</div>
		</header>

		<!-- Page content -->
		<main class="mx-auto w-full max-w-3xl flex-1 px-4 pb-16 pt-10 sm:px-8 sm:pt-14">

			<!-- Page heading -->
			<div class="mb-10 text-center sm:mb-14">
				<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-[#1a4a7a]">
					Hope Community SDA
				</p>
				<h1 class="font-display text-4xl font-semibold text-gray-900 sm:text-5xl">
					Events
				</h1>
				<p class="mx-auto mt-4 max-w-sm text-sm leading-relaxed text-gray-700">
					Everyone is welcome. Come as you are — whether it’s your first time or you’ve been with us for years.
				</p>
			</div>

			<!-- Upcoming Events -->
			<section class="mb-12">
				<h2 class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-[#1a4a7a]">
					Upcoming Events
				</h2>
				<ul class="space-y-3">
					{upcomingEvents.map((event) => {
						const [day, month] = event.date.split(' ')
						const monthShort = month.slice(0, 3)
						return (
							<li class="flex items-stretch overflow-hidden rounded-2xl border border-black/8 bg-white shadow-sm">
								<!-- Date badge -->
								<div class="flex w-16 shrink-0 flex-col items-center justify-center border-r border-blue-200 bg-blue-100 py-5">
									<span class="font-display text-2xl font-bold leading-none text-blue-900">
										{day}
									</span>
									<span class="mt-1 text-[0.6rem] font-semibold uppercase tracking-wider text-blue-800 sm:hidden">
										{monthShort}
									</span>
									<span class="mt-1 hidden text-[0.6rem] font-semibold uppercase tracking-wider text-blue-800 sm:block">
										{month}
									</span>
								</div>
								<!-- Content -->
								<div class="flex flex-1 flex-col justify-center px-4 py-4">
									<h3 class="text-sm font-semibold text-gray-900 sm:text-base">
										{event.title}
									</h3>
									<p class="mt-0.5 text-sm leading-relaxed text-gray-600">
										{event.description}
									</p>
								</div>
							</li>
						)
					})}
				</ul>
			</section>

			<!-- Weekly Services -->
			<section>
				<h2 class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-[#1a4a7a]">
					Weekly Services
				</h2>
				<div class="grid gap-3 sm:grid-cols-2">
					{regularEvents.map((group) => (
						<div class="rounded-2xl border border-black/8 bg-white p-5 shadow-sm">
							<h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500">
								{group.day}s
							</h3>
							<ul class="space-y-2.5">
								{group.items.map((item) => (
									<li class="flex items-center gap-3">
										<span class="inline-flex shrink-0 items-center rounded-lg border border-blue-200 bg-blue-50 px-2.5 py-1 font-mono text-xs font-semibold text-blue-800">
											{item.time}
										</span>
										<span class="text-sm font-medium text-gray-800">{item.label}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</section>

			<!-- Venue note -->
			<p class="mt-10 text-center text-sm text-gray-600">
				All events take place at our church unless otherwise stated.
				<a
					href={SITE.address.mapsUrl}
					target="_blank"
					rel="noreferrer"
					class="ml-1 font-semibold text-[#1a4a7a] underline underline-offset-2 transition hover:text-blue-900"
				>
					{SITE.address.line1}, {SITE.address.line2}
				</a>
			</p>

		</main>

		<!-- Footer -->
		<footer class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-4 border-t border-black/8 px-4 py-6 text-center sm:flex-row sm:px-8 sm:text-left">
			<p class="text-xs leading-relaxed text-gray-600">
				© {new Date().getFullYear()} Hope Community SDA Church · Beckenham, Bromley. · <a href="https://derrick.dk" target="_blank" rel="noreferrer" class="hover:text-gray-900 transition">Website by Derrick.dk</a>
			</p>
			<div class="flex items-center gap-3" aria-label="Follow us">
				<a
					href={SITE.social.facebook}
					target="_blank"
					rel="noreferrer"
					aria-label="Facebook"
					class="grid h-9 w-9 place-items-center rounded-full border border-black/10 bg-white text-gray-600 transition hover:text-gray-900"
				>
					<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.1.4-2 2-2h2V2.2C16.6 2.1 15.3 2 14 2c-3 0-5 1.8-5 5.1V10H6v4h3v8h4z" /></svg>
				</a>
				<a
					href={SITE.social.instagram}
					target="_blank"
					rel="noreferrer"
					aria-label="Instagram"
					class="grid h-9 w-9 place-items-center rounded-full border border-black/10 bg-white text-gray-600 transition hover:text-gray-900"
				>
					<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
						<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
					</svg>
				</a>
				<a
					href={SITE.social.youtube}
					target="_blank"
					rel="noreferrer"
					aria-label="YouTube"
					class="grid h-9 w-9 place-items-center rounded-full border border-black/10 bg-white text-gray-600 transition hover:text-red-600"
				>
					<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 7.3s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.9 3.8 12 3.8 12 3.8s-4.9 0-7.9.2c-.4.1-1.4.1-2.2 1C1.2 5.7 1 7.3 1 7.3S.8 9.2.8 11.1v1.8C.8 14.8 1 16.7 1 16.7s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.7.2 7.7.2s4.9 0 7.9-.2c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.8c0-1.9-.2-3.8-.2-3.8zM9.8 14.9V8.5l6.2 3.2-6.2 3.2z" /></svg>
				</a>
			</div>
		</footer>

	</div>
</Base>
