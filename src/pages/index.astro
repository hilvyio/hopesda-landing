---
import Base from '../layouts/Base.astro'
import HeroVideo from '../components/HeroVideo.astro'
import { SITE, ASSETS } from '../lib/const'

const pageTitle = `${SITE.name} — New home, coming soon`
const pageDescription =
	'We’re building a new home for Hope Community SDA Church online. Worship streams live on YouTube every Saturday — plus visit us in Beckenham, worship times, and contact details.'
---

<Base title={pageTitle} description={pageDescription}>
	<main
		class="relative min-h-[100dvh] min-h-[100svh] overflow-x-clip overflow-y-auto"
		style="isolation: isolate"
	>
		<HeroVideo />

		<!-- Top bar -->
		<header class="relative z-10 pt-safe">
			<div
				class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 pt-4 sm:gap-4 sm:px-8 sm:pt-8"
			>
				<a
					href="/"
					class="animate-fade flex min-w-0 flex-1 items-center gap-2.5 sm:min-w-0 sm:flex-none sm:gap-3"
					aria-label={SITE.name}
				>
					<img
						src={ASSETS.logo}
						alt=""
						width="40"
						height="40"
						class="h-10 w-10 shrink-0 rounded-full bg-white/5 object-contain p-1 ring-1 ring-white/15 sm:h-11 sm:w-11"
						loading="eager"
					/>
					<span
						class="truncate text-left text-sm font-semibold leading-tight tracking-tight text-brand-cream sm:text-lg"
					>
						Hope SDA Church
					</span>
				</a>
				<div class="animate-fade flex shrink-0 items-center gap-2 sm:gap-3">
					<a
						href="/events"
						class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-medium text-brand-cream/90 backdrop-blur transition hover:bg-white/10"
					>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
						</svg>
						Events
					</a>
				</div>
			</div>
		</header>

		<!-- Hero content -->
		<section
			class="relative z-10 mx-auto flex max-w-5xl flex-col items-center px-4 pb-16 pt-10 text-center sm:px-8 sm:pb-20 sm:pt-24"
		>
			<span
				class="animate-fade-up inline-flex max-w-full items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-2 text-[0.65rem] font-medium uppercase leading-snug tracking-[0.14em] text-brand-sky-soft backdrop-blur delay-100 sm:px-4 sm:text-xs sm:tracking-[0.2em]"
			>
				<svg
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M12 2v4" /><path d="m16.2 7.8 2.8-2.8" /><path
						d="M18 12h4"
					/><path d="m16.2 16.2 2.8 2.8" /><path d="M12 18v4" /><path
						d="m4.9 19.1 2.8-2.8"
					/><path d="M2 12h4" /><path d="m4.9 4.9 2.8 2.8" />
				</svg>
				New home — coming soon
			</span>

			<h1
				class="animate-fade-up font-display mt-5 text-balance text-[clamp(1.85rem,6.5vw+0.6rem,3.75rem)] font-semibold leading-[1.08] tracking-tight text-brand-cream delay-200 sm:mt-6 sm:text-6xl md:text-7xl"
			>
				A seat is ready for you at
				<span class="block text-brand-sky-soft">Hope Community.</span>
			</h1>

			<p
				class="animate-fade-up text-pretty mx-auto mt-5 max-w-2xl px-0.5 text-[0.9375rem] leading-relaxed text-brand-cream/80 delay-300 sm:mt-6 sm:px-0 sm:text-lg"
			>
				We’re building a refreshed home online — but our doors are open every
				Sabbath. Until then, here’s where to find us, when we gather, and how
				to say hello.
			</p>

			<div
				class="animate-fade-up mt-8 flex flex-wrap items-center justify-center gap-3 delay-400 sm:mt-10"
			>
				<a
					href={SITE.address.mapsUrl}
					target="_blank"
					rel="noreferrer"
					class="touch-target inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-brand-cream backdrop-blur transition active:bg-white/15 hover:border-white/30 hover:bg-white/10 sm:py-2.5"
				>
					<svg
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path
							d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
						/><circle cx="12" cy="10" r="3" />
					</svg>
					Visit us
				</a>
				<a
					href={SITE.liveStream.url}
					target="_blank"
					rel="noreferrer"
					class="touch-target inline-flex items-center justify-center gap-2 rounded-full bg-[#FF0000] px-5 py-3 text-sm font-semibold text-white transition active:bg-[#cc0000] hover:bg-[#e60000] sm:py-2.5"
				>
					<svg
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="currentColor"
						class="shrink-0 opacity-95"
						aria-hidden="true"
					>
						<path
							d="M23 7.3s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.9 3.8 12 3.8 12 3.8s-4.9 0-7.9.2c-.4.1-1.4.1-2.2 1C1.2 5.7 1 7.3 1 7.3S.8 9.2.8 11.1v1.8C.8 14.8 1 16.7 1 16.7s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.7.2 7.7.2s4.9 0 7.9-.2c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.8c0-1.9-.2-3.8-.2-3.8zM9.8 14.9V8.5l6.2 3.2-6.2 3.2z"
						/>
					</svg>
					Watch live
				</a>
			</div>
		</section>

		<!-- Info cards -->
		<section
			class="relative z-10 mx-auto grid w-full max-w-6xl gap-4 px-4 pb-12 sm:grid-cols-3 sm:gap-4 sm:px-8 sm:pb-14"
		>
			<article class="glass animate-fade-up rounded-2xl p-5 sm:rounded-3xl sm:p-6 delay-500">
				<div class="flex items-center gap-3">
					<span
						class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-brand-sky/20 text-brand-sky-soft"
						aria-hidden="true"
					>
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
						</svg>
					</span>
					<h3 class="font-display text-lg font-semibold text-brand-cream">
						Worship
					</h3>
				</div>
				<p class="mt-4 text-sm text-brand-cream/80">
					{SITE.worship.day}
				</p>
				<dl class="mt-3 space-y-2.5 text-sm">
					<div
						class="grid grid-cols-[minmax(0,1fr)_auto] items-baseline gap-x-3 gap-y-0.5 text-left"
					>
						<dt class="min-w-0 text-brand-muted">Sabbath School</dt>
						<dd class="shrink-0 text-right font-medium tabular-nums text-brand-cream">
							{SITE.worship.sabbathSchool}
						</dd>
					</div>
					<div
						class="grid grid-cols-[minmax(0,1fr)_auto] items-baseline gap-x-3 gap-y-0.5 text-left"
					>
						<dt class="min-w-0 text-brand-muted">Family Service</dt>
						<dd class="shrink-0 text-right font-medium tabular-nums text-brand-cream">
							{SITE.worship.familyService}
						</dd>
					</div>
				</dl>
				<p class="mt-4 border-t border-white/10 pt-4 text-sm leading-relaxed text-brand-cream/85">
					<strong class="font-semibold text-red-300">Live every week</strong> — join us on YouTube for the full service stream.
				</p>
				<a
					href={SITE.liveStream.url}
					target="_blank"
					rel="noreferrer"
					class="mt-3 inline-flex min-h-11 items-center gap-1.5 py-1 text-sm font-bold text-[#ff6b6b] touch-manipulation hover:text-red-200"
				>
					YouTube live streams
					<svg
						width="14"
						height="14"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M5 12h14" /><path d="m13 6 6 6-6 6" />
					</svg>
				</a>
			</article>

			<article class="glass animate-fade-up rounded-2xl p-5 sm:rounded-3xl sm:p-6 delay-500">
				<div class="flex items-center gap-3">
					<span
						class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-brand-sky/20 text-brand-sky-soft"
						aria-hidden="true"
					>
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle
								cx="12"
								cy="10"
								r="3"
							/>
						</svg>
					</span>
					<h3 class="font-display text-lg font-semibold text-brand-cream">
						Find us
					</h3>
				</div>
				<address class="mt-4 block text-sm not-italic text-brand-cream/80">
					{SITE.address.line1}<br />
					{SITE.address.line2}<br />
					{SITE.address.postcode}
				</address>
				<a
					href={SITE.address.mapsUrl}
					target="_blank"
					rel="noreferrer"
					class="mt-4 inline-flex min-h-11 items-center gap-1.5 py-1 text-sm font-semibold text-brand-sky-soft touch-manipulation hover:text-brand-cream"
				>
					Get directions
					<svg
						width="14"
						height="14"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M5 12h14" /><path d="m13 6 6 6-6 6" />
					</svg>
				</a>
			</article>

			<article class="glass animate-fade-up rounded-2xl p-5 sm:rounded-3xl sm:p-6 delay-700">
				<div class="flex items-center gap-3">
					<span
						class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-brand-sky/20 text-brand-sky-soft"
						aria-hidden="true"
					>
						<svg
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path
								d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
							/><polyline points="22,6 12,13 2,6" />
						</svg>
					</span>
					<h3 class="font-display text-lg font-semibold text-brand-cream">
						Say hello
					</h3>
				</div>
				<p class="mt-4 text-sm text-brand-cream/80">
					Questions, prayer, or planning your first visit?
				</p>
				<a
					href={`mailto:${SITE.contactEmail}`}
					class="mt-4 inline-flex min-h-11 min-w-0 items-center gap-1.5 break-words py-1 text-left text-sm font-semibold text-brand-sky-soft touch-manipulation hover:text-brand-cream"
				>
					{SITE.contactEmail}
					<svg
						width="14"
						height="14"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M5 12h14" /><path d="m13 6 6 6-6 6" />
					</svg>
				</a>
			</article>
		</section>

		<!-- Footer strip -->
		<footer
			class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-5 px-4 pb-safe pt-2 text-center sm:flex-row sm:items-center sm:gap-4 sm:px-8 sm:pt-0 sm:text-left"
		>
			<p class="max-w-md text-xs leading-relaxed text-brand-muted sm:max-w-none">
				© {new Date().getFullYear()} Hope Community SDA Church · A family
				church in Beckenham, Bromley. · <a href="https://derrick.dk" target="_blank" rel="noreferrer" class="hover:text-brand-cream transition">Website by Derrick.dk</a>
			</p>
			<div class="flex items-center gap-4" aria-label="Follow us">
				<a
					href={SITE.social.facebook}
					target="_blank"
					rel="noreferrer"
					aria-label="Facebook"
					class="touch-target grid h-11 w-11 place-items-center rounded-full border border-white/15 bg-white/5 text-brand-cream/80 transition active:bg-white/10 hover:border-white/30 hover:text-brand-cream"
				>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
						><path
							d="M13 22v-8h3l1-4h-4V7.5c0-1.1.4-2 2-2h2V2.2C16.6 2.1 15.3 2 14 2c-3 0-5 1.8-5 5.1V10H6v4h3v8h4z"
						/></svg
					>
				</a>
				<a
					href={SITE.social.instagram}
					target="_blank"
					rel="noreferrer"
					aria-label="Instagram"
					class="touch-target grid h-11 w-11 place-items-center rounded-full border border-white/15 bg-white/5 text-brand-cream/80 transition active:bg-white/10 hover:border-white/30 hover:text-brand-cream"
				>
					<svg
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<rect x="2" y="2" width="20" height="20" rx="5" ry="5"
						></rect><path
							d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
						></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
					</svg>
				</a>
				<a
					href={SITE.social.youtube}
					target="_blank"
					rel="noreferrer"
					aria-label="YouTube — weekly live streams"
					class="touch-target grid h-11 w-11 place-items-center rounded-full border border-white/15 bg-white/5 text-brand-cream/80 transition active:bg-white/10 hover:border-red-500/40 hover:text-red-200"
				>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
						><path
							d="M23 7.3s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.9 3.8 12 3.8 12 3.8s-4.9 0-7.9.2c-.4.1-1.4.1-2.2 1C1.2 5.7 1 7.3 1 7.3S.8 9.2.8 11.1v1.8C.8 14.8 1 16.7 1 16.7s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.7.2 7.7.2s4.9 0 7.9-.2c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.8c0-1.9-.2-3.8-.2-3.8zM9.8 14.9V8.5l6.2 3.2-6.2 3.2z"
						/></svg
					>
				</a>
			</div>
		</footer>
	</main>
</Base>
