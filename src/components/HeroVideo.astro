---
import { ASSETS } from '../lib/const'
---

<div
	aria-hidden="true"
	class="hero-vignette pointer-events-none absolute inset-0 overflow-hidden"
>
	<video
		class="absolute inset-0 h-full w-full object-cover sm:scale-[1.02]"
		autoplay
		muted
		loop
		playsinline
		preload="metadata"
		poster={ASSETS.heroPoster}
	>
		<source src={ASSETS.heroVideoWebm} type="video/webm" />
		<source src={ASSETS.heroVideoMp4} type="video/mp4" />
	</video>
	<div class="bg-grain absolute inset-0 opacity-60 mix-blend-overlay"></div>
</div>
